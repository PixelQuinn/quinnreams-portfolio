---
const featuredProject = {
  label: "Featured Project",
  title: "Web/SEO Analytics Lab",
  summary:
    "Using GA4 and Search Console on my own portfolio site to track engagement, monitor key actions, and surface traffic and conversion opportunities.",
  tags: ["GA4", "Search Console", "SEO", "Web Analytics"],
  id: "featured-web-analytics",
  href: "/projects/web-seo-analytics-lab"
};

const supportingProjects = [
  {
    title: "Marketing Impact Evaluation",
    summary:
      "Evaluating whether a marketing change measurably improved conversions using pre/post analysis and program evaluation logic.",
    tags: ["Evaluation", "Conversion Analysis", "Dashboard"],
    id: "project-marketing-impact",
    href: "#projects"
  },
  {
    title: "Marketing KPI Dashboard",
    summary:
      "Building a SQL-first dashboard with clean metric definitions, reusable queries, and stakeholder-ready reporting.",
    tags: ["SQL", "Dashboard", "KPI Design"],
    id: "project-marketing-dashboard",
    href: "#projects"
  },
  {
    title: "CRM / Lifecycle Analytics",
    summary:
      "Analyzing cohorts, retention, and customer segments to identify stronger lifecycle and engagement opportunities.",
    tags: ["Cohorts", "Retention", "Segmentation"],
    id: "project-crm-analytics",
    href: "#projects"
  },
  {
    title: "Forecasting for Marketing",
    summary:
      "Forecasting traffic, leads, and conversions with baseline models, backtesting, and accuracy metrics for planning.",
    tags: ["Forecasting", "Backtesting", "Marketing Planning"],
    id: "project-forecasting",
    href: "#projects"
  }
];
---

<section id="projects"
class="featured-projects section">
  <div class="container">
    <div class="section-heading">
      <div class="heading-line"></div>
      <h2 class="section-title featured-title">Featured Projects</h2>
      <div class="heading-line"></div>
    </div>

    <article class="featured-card">
      <div class="featured-copy">
        <p class="featured-label">{featuredProject.label}</p>
        <h3>{featuredProject.title}</h3>
        <p>{featuredProject.summary}</p>

        <div class="tag-row">
          {featuredProject.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>

        <a href={featuredProject.href} class="btn featured-btn" id={featuredProject.id}>View Case Study</a>
      </div>

      <div class="featured-visual" aria-hidden="true">
        <div class="visual-shell">
          <div class="visual-topbar"></div>

          <div class="visual-grid">
            <div class="visual-large-chart">
              <span></span>
              <span></span>
              <span></span>
              <span></span>
              <span></span>
            </div>

            <div class="visual-mini visual-donut"></div>

            <div class="visual-mini visual-bars">
              <span></span>
              <span></span>
              <span></span>
            </div>
          </div>

          <div class="visual-float"></div>
        </div>
      </div>
    </article>

    <div class="secondary-grid">
      {supportingProjects.map((project) => (
        <article class="secondary-card">
          <div class="secondary-copy">
            <h3>{project.title}</h3>
            <p>{project.summary}</p>

            <div class="tag-row secondary-tags">
              {project.tags.map((tag) => (
                <span class="tag secondary-tag">{tag}</span>
              ))}
            </div>

            <a href={project.href} class="secondary-link" id={project.id}>View Project</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .featured-projects {
    background: var(--color-white);
    padding-top: 1rem;
  }

  .section-heading {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .featured-title {
    margin-bottom: 0;
    font-size: 1.5rem;
    white-space: nowrap;
  }

  .heading-line {
    height: 1px;
    background: var(--color-border);
    flex: 1;
  }

  .featured-card {
    background: linear-gradient(135deg, var(--color-navy), var(--color-blue));
    border-radius: 1.25rem;
    padding: 2rem;
    color: var(--color-white);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: center;
    box-shadow: 0 20px 40px rgba(0, 30, 68, 0.18);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .featured-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 28px 54px rgba(0, 30, 68, 0.24);
  }

  .featured-label {
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.78);
    margin-bottom: 0.8rem;
  }

  .featured-copy h3 {
    font-size: 2rem;
    line-height: 1.05;
    margin-bottom: 0.9rem;
    font-family: Georgia, "Times New Roman", serif;
  }

  .featured-copy p {
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.92);
    max-width: 32rem;
    margin-bottom: 1rem;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 1.4rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 700;
    background: rgba(255, 255, 255, 0.12);
    color: var(--color-white);
    border: 1px solid rgba(255, 255, 255, 0.18);
    transition: background 0.25s ease, border-color 0.25s ease, transform 0.25s ease;
  }

  .featured-card:hover .tag {
    background: rgba(255, 255, 255, 0.18);
    border-color: rgba(255, 255, 255, 0.28);
  }

  .featured-btn {
    background: var(--color-white);
    color: var(--color-navy);
    border: 1px solid var(--color-white);
    transition: transform 0.25s ease, background 0.25s ease;
}

  .featured-btn:hover {
    background: #f2f6fb;
    transform: translateY(-1px);
  }

  .featured-visual {
    display: flex;
    justify-content: center;
  }

  .visual-shell {
    position: relative;
    width: 100%;
    max-width: 470px;
    min-height: 280px;
    background: rgba(255, 255, 255, 0.96);
    border-radius: 1.1rem;
    padding: 1rem;
    box-shadow: 0 18px 34px rgba(0, 30, 68, 0.16);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .featured-card:hover .visual-shell {
    transform: translateY(-4px);
    box-shadow: 0 24px 44px rgba(0, 30, 68, 0.2);
  }

  .visual-topbar {
    height: 14px;
    width: 120px;
    background: #d9e6f3;
    border-radius: 999px;
    margin-bottom: 1rem;
  }

  .visual-grid {
    display: grid;
    grid-template-columns: 1.5fr 0.9fr;
    grid-template-rows: 1fr 1fr;
    gap: 0.9rem;
  }

  .visual-large-chart,
  .visual-mini {
    background: #f8fbff;
    border: 1px solid #dbe4f0;
    border-radius: 0.95rem;
    padding: 1rem;
  }

  .visual-large-chart {
    grid-row: span 2;
    min-height: 210px;
    display: flex;
    align-items: end;
    gap: 0.65rem;
  }

  .visual-large-chart span {
    flex: 1;
    border-radius: 0.4rem 0.4rem 0 0;
    background: linear-gradient(180deg, var(--color-light-blue), var(--color-blue));
  }

  .visual-large-chart span:nth-child(1) { height: 32%; }
  .visual-large-chart span:nth-child(2) { height: 52%; }
  .visual-large-chart span:nth-child(3) { height: 44%; }
  .visual-large-chart span:nth-child(4) { height: 70%; }
  .visual-large-chart span:nth-child(5) { height: 86%; }

  .visual-donut {
    display: grid;
    place-items: center;
    position: relative;
  }

  .visual-donut::before {
    content: "";
    width: 68px;
    height: 68px;
    border-radius: 50%;
    background: conic-gradient(
      var(--color-blue) 0 58%,
      var(--color-light-blue) 58% 82%,
      #dce8f5 82% 100%
    );
  }

  .visual-donut::after {
    content: "";
    position: absolute;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: white;
  }

  .visual-bars {
    display: flex;
    align-items: end;
    gap: 0.5rem;
  }

  .visual-bars span {
    flex: 1;
    border-radius: 0.35rem 0.35rem 0 0;
    background: linear-gradient(180deg, var(--color-light-blue), var(--color-blue));
  }

  .visual-bars span:nth-child(1) { height: 30%; }
  .visual-bars span:nth-child(2) { height: 58%; }
  .visual-bars span:nth-child(3) { height: 74%; }

  .visual-float {
    position: absolute;
    left: -24px;
    bottom: 22px;
    width: 110px;
    height: 78px;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid #dbe4f0;
  }

  .secondary-grid {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .secondary-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    box-shadow: 0 14px 30px rgba(0, 30, 68, 0.08);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .secondary-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 18px 38px rgba(0, 30, 68, 0.12);
    border-color: #c7d9ed;
  }

  .secondary-copy {
    padding: 1.25rem;
  }

  .secondary-copy h3 {
    font-size: 1.15rem;
    color: var(--color-navy);
    margin-bottom: 0.6rem;
  }

  .secondary-copy p {
    font-size: 0.96rem;
    line-height: 1.6;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }

  .secondary-tag {
    background: #eef4fb;
    color: var(--color-blue);
    border: 1px solid #dbe4f0;
    transition: background 0.25s ease, border-color 0.25s ease, transform 0.25s ease;
  }

  .secondary-card:hover .secondary-tag {
    background: #e3edf9;
    border-color: #c8d9ec;
  }

  .secondary-tag {
    background: #eef4fb;
    color: var(--color-blue);
    border: 1px solid #dbe4f0;
  }

  .secondary-link {
    position: relative;
    display: inline-block;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-blue);
    transition: color 0.25s ease;
  }

  .secondary-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -3px;
    width: 0;
    height: 2px;
    background: var(--color-blue);
    transition: width 0.25s ease;
  }

  .secondary-link:hover {
    color: var(--color-navy);
  }

  .secondary-link:hover::after {
    width: 100%;
  }

  @media (max-width: 900px) {
    .featured-card {
      grid-template-columns: 1fr;
    }

    .secondary-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .section-heading {
      gap: 0.75rem;
    }

    .featured-title {
      font-size: 1.3rem;
    }

    .featured-card {
      padding: 1.5rem;
    }

    .featured-copy h3 {
      font-size: 1.65rem;
    }

    .visual-float {
      display: none;
    }
  }
</style>